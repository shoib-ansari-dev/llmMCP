# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
#
# This application supports two database backends:
# - SQLite (default for local development)
# - PostgreSQL (for production)
#
# The database type is determined by:
# 1. DATABASE_TYPE environment variable (explicit)
# 2. ENVIRONMENT variable (implicit: production = PostgreSQL, development = SQLite)
#

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
#
# This application uses LOCAL LLM via Docker Desktop's OpenAI-compatible API.
# No external API keys required!
#
# The local LLM is exposed at: http://localhost:12434/engines/v1
# Model: ai/smollm2:360M-Q4_K_M
#
# To start the local LLM:
#   docker model run ai/smollm2:360M-Q4_K_M "test"
#
# Configuration:
# LOCAL_LLM_URL=http://localhost:12434/engines/v1
# LLM_MODEL=ai/smollm2:360M-Q4_K_M

# -----------------------------------------------------------------------------
# Environment (determines default database type)
# -----------------------------------------------------------------------------
# Options: development, staging, production
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Explicit Database Type Override (optional)
# -----------------------------------------------------------------------------
# Options: sqlite, postgresql
# DATABASE_TYPE=sqlite

# -----------------------------------------------------------------------------
# SQLite Configuration (Local Development)
# -----------------------------------------------------------------------------
# SQLite database file path (relative to project root)
SQLITE_PATH=./data/app.db

# -----------------------------------------------------------------------------
# PostgreSQL Configuration (Production)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=docanalysis
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=docanalysis

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# =============================================================================
# QUICK START
# =============================================================================
#
# For LOCAL DEVELOPMENT (SQLite - no setup required):
#   1. Copy this file to .env
#   2. Set ENVIRONMENT=development
#   3. Run the app - SQLite database will be created automatically at ./data/app.db
#
# For PRODUCTION (PostgreSQL):
#   1. Copy this file to .env
#   2. Set ENVIRONMENT=production
#   3. Configure POSTGRES_* variables with your PostgreSQL credentials
#   4. Run migrations: alembic upgrade head
#   5. Run the app
#

