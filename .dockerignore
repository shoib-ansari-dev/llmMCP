# =================================
# Docker Ignore File
# =================================

# Git
.git
.gitignore

# Python
__pycache__
*.py[cod]
*$py.class
*.so
.Python
.venv
venv
env
.eggs
*.egg-info
.pytest_cache
.coverage
htmlcov

# Node
node_modules
frontend/node_modules
frontend/dist
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea
.vscode
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Data (will be mounted as volume)
data/

# Local env files
.env
.env.local

# Deployment (don't include in context)
deployment/

# Tests
tests/
*.test.py

# Documentation
*.md
!README.md
docs/

# Misc
*.log
*.tmp

