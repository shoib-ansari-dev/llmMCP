# =================================
# Document Analysis Agent - Environment Variables
# =================================
# API Key (xAI Grok or OpenAI)
OPENAI_API_KEY=your_api_key_here
# ChromaDB Settings
CHROMA_PERSIST_DIRECTORY=./data/chroma
# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text  # text or json
# App Settings
DEBUG=false
