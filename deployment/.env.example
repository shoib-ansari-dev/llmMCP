# =================================
# Document Analysis Agent - Environment Variables
# =================================
# API Key (xAI Grok or OpenAI)
OPENAI_API_KEY=your_api_key_here
# ChromaDB Settings
CHROMA_PERSIST_DIRECTORY=/app/data/chroma
# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
# Same-Site Security (IMPORTANT for production)
# Set these to your actual frontend/backend URLs
SAME_SITE_ENFORCE=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,localhost:8000,127.0.0.1
# For Azure deployment, update these:
# ALLOWED_ORIGINS=http://YOUR_AZURE_IP:3000
# ALLOWED_HOSTS=YOUR_AZURE_IP,YOUR_AZURE_IP:8000
# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
# App Settings
DEBUG=false
# =================================
# Authentication Settings
# =================================
# Dev mode - set to false in production!
AUTH_DEV_MODE=false
# JWT Settings (use long random string in production)
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Google OAuth (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://YOUR_DOMAIN:8000/auth/google/callback
# Email SMTP (for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
# Frontend URL (for password reset links)
FRONTEND_URL=http://YOUR_DOMAIN:3000
